{
  "name": "developer-dashboard",
  "version": "1.0.0",
  "description": "DevD — Developer Dashboard für Sprint-Planung, Backlog-Pflege und Live-Review (ehem. PO-Dashboard von myPrivateBabyTracker)",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"node apps/backend/src/api.js\" \"vite apps/frontend\"",
    "dev:nas": "DEVD_PROXY_TARGET=http://100.71.39.53:3001 vite apps/frontend",
    "build": "vite build apps/frontend",
    "cli": "node apps/cli/bin/devd-cli.js",
    "mcp:devd": "node apps/cli/mcp/devd-mcp.js",
    "lint": "eslint apps/frontend packages",
    "lint:fix": "eslint apps/frontend packages --fix",
    "lint:css": "stylelint \"apps/frontend/src/**/*.css\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "storybook": "LAUNCH_EDITOR=codium storybook dev -c apps/frontend/.storybook -p 6006",
    "build-storybook": "storybook build -c apps/frontend/.storybook",
    "gen:openapi": "node apps/backend/openapi/generate.js",
    "gen:openapi:check": "node apps/backend/openapi/generate.js --check",
    "gen:composition": "npm --prefix apps/frontend run gen:composition",
    "gen:composition:check": "npm --prefix apps/frontend run gen:composition:check",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "gen:mcp-notes": "node scripts/gen-mcp-notes.mjs",
    "gen:index": "node scripts/gen-index.mjs",
    "gen:index:check": "node scripts/gen-index.mjs scripts --check",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "apps/frontend/**/*.{js,jsx}": "eslint",
    "packages/**/*.js": "eslint",
    "apps/frontend/src/**/*.css": "stylelint"
  },
  "dependencies": {
    "@devd/api-types": "*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "file-type": "^22.0.1",
    "lucide-react": "^1.11.0",
    "mermaid": "^11.15.0",
    "multer": "^2.1.1",
    "sqlite-vec": "^0.1.9",
    "ws": "^8.20.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/ui": "^4.1.7",
    "dependency-cruiser": "^16.10.4",
    "es-module-lexer": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-xml-parser": "^5.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "rehype-mermaid": "^3.0.0",
    "sharp": "^0.34.5",
    "storybook": "^10.4.6",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
