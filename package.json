{
  "name": "developer-dashboard",
  "version": "1.0.0",
  "description": "DevD — Developer Dashboard für Sprint-Planung, Backlog-Pflege und Live-Review (ehem. PO-Dashboard von myPrivateBabyTracker)",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"node server/api.js\" \"vite\"",
    "dev:nas": "DEVD_PROXY_TARGET=http://100.71.39.53:3001 vite",
    "build": "vite build",
    "cli": "node bin/devd-cli.js",
    "mcp:devd": "node mcp/devd-mcp.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "storybook": "LAUNCH_EDITOR=codium storybook dev -p 6006",
    "build-storybook": "storybook build",
    "gen:openapi": "node openapi/generate.js",
    "gen:openapi:check": "node openapi/generate.js --check",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": "eslint",
    "src/**/*.css": "stylelint"
  },
  "bin": {
    "devd-cli": "bin/devd-cli.js"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@retronav/ixora": "^0.3.3",
    "@uiw/react-codemirror": "^4.25.9",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "file-type": "^22.0.1",
    "lucide-react": "^1.11.0",
    "mermaid": "^11.15.0",
    "multer": "^2.1.1",
    "note-field": "file:vendor/note-field-0.2.0.tgz",
    "sqlite-vec": "^0.1.9",
    "ws": "^8.20.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/ui": "^4.1.7",
    "dependency-cruiser": "^16.10.4",
    "es-module-lexer": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-xml-parser": "^5.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "sharp": "^0.34.5",
    "storybook": "^10.4.6",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
